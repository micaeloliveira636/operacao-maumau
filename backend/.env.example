# ==========================================================
#  Operação Maumau — Backend  (.env)
#  Copie este arquivo para ".env" e preencha os valores.
# ==========================================================

# --- Banco de dados (Neon PostgreSQL) ---
# Painel Neon > Connection Details > Connection string (com ?sslmode=require)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# --- JWT / sessão ---
# Gere strings aleatórias fortes (>=32 chars). Ex.: openssl rand -hex 32
JWT_SECRET=troque_por_uma_string_aleatoria_de_32_chars_ou_mais
REFRESH_SECRET=troque_por_outra_string_aleatoria_diferente_de_32_chars

# --- Admin inicial (usado pelo seed) ---
ADMIN_EMAIL=admin@maumau.com
ADMIN_PASSWORD=troque_essa_senha
ADMIN_WHATSAPP=+5511999999999

# --- Frontend (CORS). Aceita múltiplas origens separadas por vírgula ---
FRONTEND_URL=http://localhost:5173

# --- Cloudinary (armazenamento de mídias) ---
# Dashboard Cloudinary > Settings / API Keys
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
CLOUDINARY_FOLDER=maumau-media

# --- Web Push (VAPID) ---
# Gere com: npm run gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@maumau.com

# --- SendFlow (chip dedicado de notificações — opcional) ---
# Se vazio, as notificações por WhatsApp são ignoradas (push e in-app continuam).
SENDFLOW_API_URL=https://api.sendflow.pro
SENDFLOW_API_KEY=
SENDFLOW_NOTIFY_PATH=/v1/messages/text
SENDFLOW_NOTIFY_ACCOUNT=

# --- Ambiente ---
NODE_ENV=development
PORT=3001
